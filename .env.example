# Copy to .env.local (never commit .env.local)
SESSION_SECRET=generate-a-random-secret
BREEZY_API_KEY=your-breezy-api-token
BREEZY_COMPANY_ID=
# Deprecated: set per-user passwords via Change Password UI. Do not use shared passwords in production.
# DM_DEFAULT_PASSWORD=

# Geocoding via OpenStreetMap Nominatim (set false to use estimates only)
GEOCODING_ENABLED=true
