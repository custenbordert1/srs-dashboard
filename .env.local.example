# Copy to .env.local (never commit .env.local or real secrets).
# Restart `npm run dev` after pasting values from your old Mac.

# =============================================================================
# LOGIN / AUTH
# =============================================================================

# System: SRS Dashboard session cookies (HMAC-signed login tokens)
# Required: RECOMMENDED in production; optional in dev if BREEZY_API_KEY is set
# Used by: /api/auth/login, /api/auth/session, middleware
# SESSION_SECRET=generate-a-long-random-string

# System: Breezy HR (can double as session secret in local dev only)
# Required for login/auth: YES (or set SESSION_SECRET above)
# Also required for: Breezy jobs, Breezy candidates, recruiting intelligence, live snapshot
# Used by: /api/breezy/*, /api/recruiting/live-snapshot, /api/dm/dashboard, command center
BREEZY_API_KEY=your-breezy-api-token

# System: SRS Dashboard (deprecated shared DM password fallback)
# Required: OPTIONAL — prefer per-user passwords via Change Password UI
# DM_DEFAULT_PASSWORD=

# =============================================================================
# BREEZY HR — live recruiting source (jobs, candidates, KPIs)
# =============================================================================

# BREEZY_API_KEY is defined above — REQUIRED for:
#   • Breezy jobs          → /api/breezy/jobs, job management, open positions
#   • Breezy candidates    → /api/breezy/candidates, rankings, command center
#   • Recruiting intelligence → live snapshot, forecasts, automation sections

# System: Breezy HR company record
# Required: OPTIONAL (auto-discovered from API when omitted)
# BREEZY_COMPANY_ID=

# System: Breezy Added Date calendar filters
# Required: OPTIONAL (defaults to America/Chicago)
# BREEZY_ADDED_DATE_TIMEZONE=America/Chicago

# System: Breezy sync rate-limit diagnostics
# Required: OPTIONAL
# BREEZY_SYNC_MAX_REQUESTS_PER_MINUTE=40

# =============================================================================
# RECRUITING GOOGLE SHEET — archive / reference only (NOT live KPI source)
# =============================================================================

# System: Google Sheets (recruiting archive tab)
# Required: OPTIONAL — built-in default sheet id when unset
# Used by: /api/recruiting-sheet, manager summary, post queue (reference)
# GOOGLE_SHEET_ID=your-recruiting-archive-sheet-id

# System: Google Sheets tab gid
# Required: OPTIONAL (defaults to 0)
# GOOGLE_SHEET_GID=0

# System: Legacy feature flag — do NOT enable unless comparing sheet vs Breezy
# Required: OPTIONAL (keep false)
# RECRUITING_SHEET_LIVE_SOURCE=false

# System: Client-visible legacy flag (no secrets — boolean only)
# Required: OPTIONAL (keep false)
# NEXT_PUBLIC_RECRUITING_SHEET_LIVE_SOURCE=false

# =============================================================================
# MEL PROJECTS — Google Sheet for workforce / coverage intelligence
# =============================================================================

# System: Google Sheets (MEL projects tab)
# Required for MEL projects: YES
# Used by: /api/mel-projects, /api/coverage-risk, /api/rep-intelligence, workforce intelligence
GOOGLE_MEL_PROJECTS_SHEET_ID=your-mel-projects-sheet-id

# System: Google Sheets tab gid
# Required: OPTIONAL (defaults to 0)
# GOOGLE_MEL_PROJECTS_SHEET_GID=0

# =============================================================================
# HELLOSIGN / DROPBOX SIGN — offer packets (optional)
# =============================================================================

# System: Dropbox Sign (HelloSign) API
# Required: OPTIONAL — only for /api/hellosign/*
# HELLOSIGN_API_KEY=your-hellosign-api-key

# =============================================================================
# GEOCODING
# =============================================================================

# System: OpenStreetMap Nominatim (address geocoding)
# Required: OPTIONAL (set false to disable network geocoding)
GEOCODING_ENABLED=true
